{
  "name": "enable-navigation-icons",
  "version": "0.1.0",
  "description": "Easily add icons to Navigation Block items.",
  "author": "Trent Stromkins",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "git://github.com/bmx269/enable-navigation-icons.git"
  },
  "scripts": {
    "build": "wp-scripts build",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js",
    "lint:js:src": "wp-scripts lint-js ./src",
    "lint:js:src:fix": "wp-scripts lint-js ./src --fix",
    "start": "wp-scripts start",
    "packages-update": "wp-scripts packages-update",
    "update-pot": "wp i18n make-pot . languages/enable-navigation-icons.pot --exclude=src",
    "plugin-zip": "wp-scripts plugin-zip"
  },
  "dependencies": {
    "@wordpress/block-editor": "^15.14.0",
    "@wordpress/components": "^32.3.0",
    "@wordpress/compose": "^7.41.0",
    "@wordpress/data": "^10.41.0",
    "@wordpress/element": "^6.41.0",
    "@wordpress/hooks": "^4.41.0",
    "@wordpress/i18n": "^6.14.0",
    "@wordpress/primitives": "^4.41.0",
    "classnames": "^2.3.2",
    "html-react-parser": "^5.1.12",
    "lodash": "^4.17.21",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@wordpress/icons": "^9.35.0",
    "@wordpress/scripts": "^31.6.0",
    "webpack-remove-empty-scripts": "^0.8.4"
  }
}
